{
  "collectionName": "components_journal_video",
  "info": {
    "displayName": "Template: Video",
    "description": "Ein Video direkt im Notizbuch – Upload oder externer Link (z.B. Vimeo)"
  },
  "attributes": {
    "introText": {
      "type": "richtext",
      "description": "Text vor dem Video"
    },
    "videoSource": {
      "type": "enumeration",
      "enum": ["upload", "vimeo", "youtube"],
      "required": true,
      "default": "upload",
      "description": "Woher kommt das Video?"
    },
    "videoFile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["videos"],
      "description": "Videodatei – nur bei videoSource=upload (MP4 empfohlen)"
    },
    "videoUrl": {
      "type": "string",
      "description": "URL – nur bei videoSource=vimeo oder youtube, z.B. https://vimeo.com/123456"
    },
    "videoPoster": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "Vorschaubild das vor dem Abspielen angezeigt wird"
    },
    "caption": {
      "type": "string",
      "description": "Optionaler Untertitel unter dem Video"
    },
    "afterText": {
      "type": "richtext",
      "description": "Text nach dem Video – z.B. Reflexionsfragen"
    }
  }
}
