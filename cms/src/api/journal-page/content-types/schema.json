{
  "kind": "collectionType",
  "collectionName": "journal_pages",
  "info": {
    "singularName": "journal-page",
    "pluralName": "journal-pages",
    "displayName": "Journal Page",
    "description": "Eine Doppelseite im Notizbuch. Template bestimmt das Layout."
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "chapter": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::chapter.chapter",
      "inversedBy": "journalPages"
    },
    "pageOrder": {
      "type": "integer",
      "required": true,
      "min": 1,
      "description": "Reihenfolge im Notizbuch innerhalb des Kapitels"
    },
    "template": {
      "type": "enumeration",
      "enum": [
        "text_only",
        "image_layout_a",
        "image_layout_b",
        "exercise_embed",
        "audio_player",
        "video"
      ],
      "required": true,
      "default": "text_only",
      "description": "Waehle das Layout dieser Seite"
    },

    "content": {
      "type": "dynamiczone",
      "components": [
        "journal.text-only",
        "journal.image-layout-a",
        "journal.image-layout-b",
        "journal.exercise-embed",
        "journal.audio-player",
        "journal.video"
      ],
      "min": 1,
      "max": 1,
      "description": "Seiteninhalt – waehle die Komponente die zum Template passt"
    },

    "rightPageText": {
      "type": "richtext",
      "description": "Optionaler Text auf der rechten Buchseite (immer verfuegbar, unabhaengig vom Template)"
    },

    "stickers": {
      "type": "component",
      "repeatable": true,
      "component": "journal.sticker-placement",
      "description": "Sticker auf dieser Seite – Position in Prozent (0-100)"
    }
  }
}
