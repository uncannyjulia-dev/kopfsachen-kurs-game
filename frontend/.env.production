# .env.production
# Wird beim Build auf dem GitHub Actions Runner geladen.
# Werte kommen aus GitHub Secrets – nie direkt hier eintragen!
#
# In GitHub: Settings → Secrets → Actions → New secret
#   VITE_STRAPI_URL   → z.B. https://kopfsachen.strapiapp.com
#   VITE_STRAPI_TOKEN → read-only API Token aus Strapi Cloud

VITE_STRAPI_URL=
VITE_STRAPI_TOKEN=
