# .env.example
# Kopiere diese Datei zu .env.local für lokale Entwicklung.
# .env.local wird NICHT ins Git committed (steht im .gitignore).
#
# Vite macht VITE_* Variablen zur Build-Zeit verfügbar.
# Sie landen im kompilierten JS – also nur read-only Tokens verwenden!

VITE_STRAPI_URL=http://localhost:1337
VITE_STRAPI_TOKEN=dein-read-only-token-hier
