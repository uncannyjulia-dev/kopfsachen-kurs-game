{
  "collectionName": "components_journal_sticker_placements",
  "info": {
    "displayName": "Sticker Placement",
    "description": "Ein Sticker auf einer Journal-Seite mit Positions- und Groessenangabe"
  },
  "attributes": {
    "asset": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::cave-asset.cave-asset",
      "description": "Welches Asset als Sticker verwendet wird"
    },
    "x": {
      "type": "decimal",
      "required": true,
      "min": 0,
      "max": 100,
      "description": "Horizontale Position in % (0=links, 100=rechts)"
    },
    "y": {
      "type": "decimal",
      "required": true,
      "min": 0,
      "max": 100,
      "description": "Vertikale Position in % (0=oben, 100=unten)"
    },
    "scale": {
      "type": "decimal",
      "default": 1.0,
      "description": "Groesse: 1.0=Original, 0.5=halb so gross, 1.5=groesser"
    },
    "rotation": {
      "type": "decimal",
      "default": 0,
      "description": "Drehung in Grad, z.B. 12 fuer leicht nach rechts gedreht"
    },
    "zIndex": {
      "type": "integer",
      "default": 1,
      "description": "Ebene: hoehere Zahl = weiter vorne"
    }
  }
}
